{
  "theme": {
    "background_color": "#FFFFFF",
    "text_color": "#111827",
    "border_color": "#D1D5DB",
    "error_color": "#B91C1C"
  },
  "form_title": "Campaign Setup",
  "fields": [
    {
      "id": "campaign_name",
      "order": 1,
      "type": "TEXT",
      "subtype": "PLAIN",
      "label": "Campaign Name",
      "placeholder": "e.g., Summer Sale",
      "default_value": "",
      "max_length": 30,
      "error_message": "Name is required.",
      "required": true
    },
    {
      "id": "ad_networks",
      "order": 2,
      "type": "DROPDOWN",
      "label": "Ad Networks",
      "allow_multiple": true,
      "default_values": [
        "net_meta"
      ],
      "required": true,
      "options": [
        {
          "id": "net_google",
          "label": "Google Search"
        },
        {
          "id": "net_meta",
          "label": "Meta Platforms"
        }
      ]
    },
    {
      "id": "daily_budget",
      "order": 3,
      "type": "TEXT",
      "subtype": "NUMBER",
      "label": "Daily Budget ($)",
      "placeholder": "100",
      "default_value": "",
      "required": true
    },
    {
      "id": "website",
      "order": 4,
      "type": "TEXT",
      "subtype": "URI",
      "label": "Website",
      "placeholder": "https://",
      "default_value": "",
      "required": false
    },
    {
      "id": "password",
      "order": 5,
      "type": "TEXT",
      "subtype": "SECURE",
      "label": "Password",
      "placeholder": "Password",
      "default_value": "",
      "required": false
    },
    {
      "id": "description",
      "order": 6,
      "type": "TEXT",
      "subtype": "MULTILINE",
      "label": "Description",
      "placeholder": "Write here...",
      "default_value": "",
      "required": false
    },
    {
      "id": "notifications",
      "order": 7,
      "type": "TOGGLE",
      "label": "Enable Notifications",
      "default_value": true,
      "required": false
    },
    {
      "id": "accept_legal",
      "order": 8,
      "type": "CHECKBOX",
      "label": "I agree to the Terms of Service.",
      "required": true,
      "error_message": "Please accept terms.",
      "metadata": {
        "Terms of Service": "https://example.com/terms"
      },
      "clickable_text_color": "#2563EB"
    }
  ]
}
